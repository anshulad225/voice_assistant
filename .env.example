# Telephony Provider (twilio / exotel / telecmi)
# For India: use telecmi (14-day free trial, supports Indian numbers)
TELEPHONY_PROVIDER=telecmi

# TeleCMI Configuration (recommended for India)
# Sign up at https://telecmi.com → Dashboard → Settings → API
TELECMI_APP_ID=your_app_id_here
TELECMI_SECRET=your_secret_here
# From HTTP ngrok output: wss://xxxx.ngrok-free.dev/voice/stream  (no TCP ngrok needed)
TELECMI_WS_URL=wss://your-ngrok-url.ngrok-free.dev/voice/stream

# Twilio Configuration (only needed if TELEPHONY_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Exotel Configuration (only needed if TELEPHONY_PROVIDER=exotel)
EXOTEL_API_KEY=your_exotel_api_key_here
EXOTEL_API_TOKEN=your_exotel_api_token_here
EXOTEL_SID=your_exotel_sid_here

# Google AI Configuration (free tier at https://aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./dental_intake.db

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
